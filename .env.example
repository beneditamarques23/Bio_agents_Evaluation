# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.

# FutureHouse / Edison Scientific (required for Crow / Falcon / Robin)
# Get a key at https://platform.edisonscientific.com
FUTUREHOUSE_API_KEY=
FUTUREHOUSE_API_URL=https://api.platform.edisonscientific.com

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google (free tier at aistudio.google.com)
GOOGLE_API_KEY=

# Groq (free tier at console.groq.com)
GROQ_API_KEY=

# Biomni shared data directory (~11 GB downloaded on first agent.go() call)
BIOMNI_DATA_PATH=./data

# Local (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Cloud (remote GPU inference — free tier available)
# 1. Create a key at https://ollama.com/settings/keys
# 2. Browse cloud models at https://ollama.com/search?c=cloud
OLLAMA_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com

# AWS Bedrock (optional)
AWS_PROFILE=
AWS_REGION=us-west-2
